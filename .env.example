# 服务器配置
HOST=0.0.0.0
PORT=8765
DEBUG=true

# 认证配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=60

# 模型提供商配置
LLM_PROVIDER=openai  # openai, kimi, deepseek, mock

# OpenAI 配置 (用于DeepSeek等兼容API)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Kimi 配置 (假设使用OpenAI兼容API)
KIMI_API_KEY=sk-SjS1lSdsNBTWnAbrV5dLmREKLWK13ReDtzSxqRFB0Omo0ybk
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# DeepSeek 配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 本地模型配置 (如果使用本地LLM)
LOCAL_MODEL_PATH=./models/
LOCAL_MODEL_NAME=llama-2-7b

# 加密配置 (可选)
ENCRYPTION_KEY=your-32-byte-encryption-key-for-aes-gcm

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/x_websocket.log